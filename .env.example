# Copy to .env — never commit the real file.

# ── LLM (Google Gemini — free tier: 1500 req/day) ──────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── LangSmith (optional but recommended) ───────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=edadvisor-genai

# ── Embeddings ──────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ── FAISS index ─────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=data/vector_store

# ── Redis (conversation memory) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=7200

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./edadvisor.db

# ── RAG tuning ───────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=20
TOP_K_FINAL=5
SIMILARITY_THRESHOLD=0.72
CONFIDENCE_ESCALATION_THRESHOLD=0.65
ACTIVE_PROMPT_VERSION=v2

# ── Corpus ───────────────────────────────────────────────────────────────────
CORPUS_DIR=data/corpus
CHUNK_STRATEGY=hierarchical
CHUNK_SIZE=800
CHUNK_OVERLAP=150
